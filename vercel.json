{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "框架": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ]
}
